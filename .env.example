# ---- Database (your local PostgreSQL / pgAdmin) ----
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PG_PASSWORD@localhost:5432/ecomm

# ---- Admin login (you will use this to log in to /admin) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ---- JWT secret (any long random string) ----
SECRET_KEY=change_this_to_a_long_random_secret_string_123456

# ---- Your business contact ----
# WhatsApp number that receives orders. Country code, digits only, no + or spaces.
# Example for India: 919876543210
OWNER_WHATSAPP=919876543210

# ---- UPI payment details (shown at checkout) ----
UPI_ID=yourname@upi
UPI_PAYEE_NAME=Your Store Name

# ---- Frontend origin for CORS ----
FRONTEND_ORIGIN=http://localhost:5173

# ---- Order notification to owner ----
# none = off | email | greenapi | callmebot
NOTIFY_PROVIDER=email
# Email (Gmail) — create an App Password at myaccount.google.com/apppasswords
EMAIL=youraddress@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
NOTIFY_EMAIL_TO=          # blank = receive at EMAIL
# WhatsApp providers (only if NOTIFY_PROVIDER set to these)
CALLMEBOT_APIKEY=
GREENAPI_INSTANCE=
GREENAPI_TOKEN=

# ---- Razorpay (optional; leave blank to disable the gateway) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Shipping (Shiprocket-style weight slabs; adjust to your courier rates) ----
SHIPPING_PER_500G=50       # delivery charge per 500g
FREE_SHIPPING_ABOVE=1500   # free delivery when subtotal >= this
COD_FEE=40                 # extra fee for Cash on Delivery
ENABLE_COD=True            # set False to disable COD
